{
  "name": "@phantomind/core",
  "version": "0.5.0",
  "description": "PhantomindAI — AI Context Layer with Real-Time Automation, Multi-LLM Support & Agent Orchestration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "phantomind": "dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synaptode/PhantomMind.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/synaptode/PhantomMind#readme",
  "bugs": {
    "url": "https://github.com/synaptode/PhantomMind/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "node scripts/inject-readme.cjs",
    "postpack": "node scripts/strip-readme.cjs",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "phantomind": "tsx src/cli/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "author": {
    "name": "synaptode",
    "url": "https://github.com/synaptode"
  },
  "keywords": [
    "ai",
    "llm",
    "copilot",
    "cursor",
    "cline",
    "continue",
    "claude",
    "chatgpt",
    "mcp",
    "model-context-protocol",
    "context",
    "agent",
    "automation",
    "watch",
    "monorepo",
    "developer-tools",
    "typescript",
    "phantomind"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cosmiconfig": "^9.0.0",
    "eventemitter3": "^5.0.1",
    "fast-glob": "^3.3.3",
    "glob": "^11.0.1",
    "inquirer": "^12.6.0",
    "js-yaml": "^4.1.0",
    "natural": "^8.0.1",
    "node-cron": "^3.0.3",
    "openai": "^4.86.2",
    "ora": "^8.2.0",
    "zod": "^3.24.3",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
